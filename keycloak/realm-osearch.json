{
  "realm": "osearch",
  "enabled": true,
  "displayName": "opensearch-search (local)",
  "sslRequired": "none",
  "registrationAllowed": false,
  "accessTokenLifespan": 1800,
  "components": {
    "org.keycloak.userprofile.UserProfileProvider": [
      {
        "name": "Declarative User Profile",
        "providerId": "declarative-user-profile",
        "subComponents": {},
        "config": {
          "kc.user.profile.config": [
            "{\"attributes\":[{\"name\":\"username\",\"displayName\":\"${username}\",\"validations\":{\"length\":{\"min\":3,\"max\":255},\"username-prohibited-characters\":{}},\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"multivalued\":false},{\"name\":\"email\",\"displayName\":\"${email}\",\"validations\":{\"email\":{},\"length\":{\"max\":255}},\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"multivalued\":false},{\"name\":\"firstName\",\"displayName\":\"${firstName}\",\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"multivalued\":false},{\"name\":\"lastName\",\"displayName\":\"${lastName}\",\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"multivalued\":false},{\"name\":\"orgeinheit\",\"displayName\":\"Orgeinheit\",\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\"]},\"multivalued\":false}],\"unmanagedAttributePolicy\":\"ENABLED\"}"
          ]
        }
      }
    ]
  },
  "clients": [
    {
      "clientId": "osearch-api",
      "name": "opensearch-search API",
      "description": "Resource server. Public client so a dev token can be fetched via the direct grant; the standard flow is enabled for a future UI.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": ["*"],
      "webOrigins": ["*"],
      "protocolMappers": [
        {
          "name": "audience-osearch-api",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "osearch-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "orgeinheit",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "orgeinheit",
            "claim.name": "orgeinheit",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "ermittler",
      "enabled": true,
      "emailVerified": true,
      "email": "ermittler@behoerde.example",
      "firstName": "Erika",
      "lastName": "Ermittler",
      "attributes": {
        "orgeinheit": ["K3"]
      },
      "credentials": [
        {
          "type": "password",
          "value": "ermittler",
          "temporary": false
        }
      ]
    }
  ]
}
