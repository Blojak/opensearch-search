# Copy this file to `.env.local` (gitignored) and fill in a bearer token.
#
# Stopgap auth for development only: the app sends this token as
# `Authorization: Bearer <token>` on every API call. Get one from Keycloak for a
# realm user (e.g. `ermittler`). The real login flow (authorization code / PKCE)
# replaces this later; nothing else in the app changes when it does.
VITE_DEV_TOKEN=
