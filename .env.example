# ---------------------------------------------------------------------------
# OpenSearch (single store: full text, vectors and metadata)
# ---------------------------------------------------------------------------
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
# Security plugin is disabled in docker-compose, so plain HTTP without auth.
OPENSEARCH_USE_SSL=false
OPENSEARCH_VERIFY_CERTS=false
# OPENSEARCH_USER=
# OPENSEARCH_PASSWORD=
OPENSEARCH_INDEX=chunks
# Search pipeline that normalizes + combines the lexical and vector scores for
# hybrid search (created on startup).
OPENSEARCH_HYBRID_PIPELINE=hybrid-search-pipeline

# Host port for the OpenSearch Dashboards container
OPENSEARCH_DASHBOARDS_PORT=5601

# ---------------------------------------------------------------------------
# PostgreSQL (metadata - single source of truth; OpenSearch is derived)
# ---------------------------------------------------------------------------
POSTGRES_USER=osearch
POSTGRES_PASSWORD=osearch
POSTGRES_DB=osearch
POSTGRES_HOST=localhost
# Host port for the Postgres container
POSTGRES_PORT=5433
# Optional override for Alembic only: normally the migration URL is derived
# from the POSTGRES_* values above, so leave this unset. Set it to point
# Alembic at a different database (e.g. a scratch DB when generating a
# revision) without touching the app configuration.
# ALEMBIC_DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/dbname

# ---------------------------------------------------------------------------
# pgAdmin (web UI for PostgreSQL, http://localhost:PGADMIN_PORT)
# ---------------------------------------------------------------------------
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin

# ---------------------------------------------------------------------------
# Embedding model (local, multilingual)
# ---------------------------------------------------------------------------
EMBEDDING_MODEL=intfloat/multilingual-e5-large
# Vector dimension of the model (multilingual-e5-large = 1024)
VECTOR_SIZE=1024

# ---------------------------------------------------------------------------
# HuggingFace Hub access (corporate environment)
# All optional: unset means the public hub with the default trust store.
# ---------------------------------------------------------------------------
# Internal mirror/proxy for the Hub (exported as HF_ENDPOINT).
# HF_ENDPOINT=https://huggingface.internal.example
# Access token if the mirror requires authentication.
# HF_TOKEN=
# Cache directory for downloaded models (exported as HF_HOME).
# HF_HOME=/opt/models/hf-cache
# Serve the model only from the local cache, never hit the network.
# HF_OFFLINE=false
# CA bundle (PEM) for TLS behind a proxy. If unset, REQUESTS_CA_BUNDLE /
# SSL_CERT_FILE and the system trust store are auto-detected.
# CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt

# ---------------------------------------------------------------------------
# Chunking
# ---------------------------------------------------------------------------
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ---------------------------------------------------------------------------
# Search (hybrid: relative weights of lexical BM25 vs. semantic kNN; sum ~1.0)
# ---------------------------------------------------------------------------
HYBRID_LEXICAL_WEIGHT=0.5
HYBRID_SEMANTIC_WEIGHT=0.5

# ---------------------------------------------------------------------------
# Keycloak (OIDC identity provider, http://localhost:KEYCLOAK_PORT)
# The realm "osearch" with the API client and a test user is imported from
# keycloak/realm-osearch.json on first start.
# ---------------------------------------------------------------------------
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ---------------------------------------------------------------------------
# OIDC — the API is a resource server and validates the IdP's bearer tokens.
# REQUIRED (no defaults in code): the app refuses to start without them, so a
# missing/misspelled value in a Kubernetes ConfigMap fails loudly instead of
# silently trusting the wrong issuer.
# ---------------------------------------------------------------------------
OIDC_ISSUER=http://localhost:8080/realms/osearch
OIDC_AUDIENCE=osearch-api
# Seconds the JWKS is cached (an unknown key id refetches immediately anyway).
OIDC_JWKS_TTL=300

# ---------------------------------------------------------------------------
# Flask API
# ---------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=5002
